# Copy to your workflow repository as deploy/compose.env.
# This committed file contains only non-secret values. `make bootstrap` writes
# the platform root compose.env with AGE_IDENTITY, LLM_API_KEY, PG_PASSWORD,
# and OBJECT_STORE_SECRET_KEY.

PG_DB=agentic_ops
PG_USER=agentic_ops
OBJECT_STORE_ACCESS_KEY=agentic_ops

# Hindsight is a direct container, so its model endpoint/model configuration is
# supplied before it can load platform-config.yaml.
HINDSIGHT_API_LLM_PROVIDER=openai
HINDSIGHT_API_LLM_BASE_URL=https://llm.example.internal/v1
HINDSIGHT_API_LLM_MODEL=example-chat-model
HINDSIGHT_API_EMBEDDINGS_PROVIDER=openai
HINDSIGHT_API_EMBEDDINGS_OPENAI_BASE_URL=https://llm.example.internal/v1
HINDSIGHT_API_EMBEDDINGS_OPENAI_MODEL=example-embedding-model
